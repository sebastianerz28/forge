{
  "Forge": {
    "Runner": {
      "Id": null,
      "Name": "seb-pc",
      "HeartbeatIntervalSeconds": 30,
      "DeadTimeoutSeconds": 120
    },
    "GitHub": {
      "Owner": "owner",
      "OwnerUsername": "owner",
      "TokenEnv": "GITHUB_TOKEN",
      "PollIntervalSeconds": 60,
      "ReviewPollIntervalSeconds": 30
    },
    "TargetRepos": [
      {
        "Name": "repo",
        "Label": "forge-ready",
        "ClonePath": "/home/seb/dev/repo"
      }
    ],
    "Postgres": {
      "ConnectionStringEnv": "FORGE_DB_URL"
    },
    "Executor": {
      "Backend": "cli",
      "Cli": {
        "Command": "claude",
        "TimeoutSeconds": 600
      },
      "Api": {
        "Model": "claude-sonnet-4-20250514",
        "ApiKeyEnv": "ANTHROPIC_API_KEY"
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  }
}
